{
  "name": "agent-eval-bench",
  "version": "0.1.0",
  "description": "Playwright + Lighthouse + Vitest for AI coding agents",
  "type": "module",
  "bin": {
    "agent-eval-bench": "./src/bin.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun run src/bin.ts",
    "build": "bun run scripts/build.ts",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "lint": "tsc --noEmit"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@agent-eval-bench/core": "workspace:*",
    "@agent-eval-bench/sandbox": "workspace:*",
    "@agent-eval-bench/adapters": "workspace:*",
    "@agent-eval-bench/scoring": "workspace:*",
    "@agent-eval-bench/telemetry": "workspace:*",
    "@agent-eval-bench/runner": "workspace:*",
    "@agent-eval-bench/reporter": "workspace:*",
    "@agent-eval-bench/benchmarks": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "ink": "^5.1.0",
    "listr2": "^8.2.5",
    "ora": "^8.1.1",
    "react": "^18.3.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "typescript": "^5.7.3"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "keywords": [
    "ai",
    "agents",
    "benchmark",
    "evaluation",
    "cli"
  ],
  "license": "MIT",
  "engines": {
    "bun": ">=1.1.0"
  }
}
